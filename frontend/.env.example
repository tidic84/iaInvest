# ============================================
# TRADING IA AUTO-APPRENANT - FRONTEND CONFIG
# ============================================

# URL de l'API Backend
# Développement local:
VITE_API_URL=http://localhost:8000

# Production (modifier avec votre domaine):
# VITE_API_URL=https://api.yourdomain.com

# URL WebSocket
# Développement local:
VITE_WS_URL=ws://localhost:8000/ws

# Production (modifier avec votre domaine):
# VITE_WS_URL=wss://api.yourdomain.com/ws

# Mode de build
VITE_MODE=development

# ============================================
# ANALYTICS & MONITORING (Optionnel)
# ============================================

# Google Analytics
VITE_GOOGLE_ANALYTICS_ID=

# Sentry (Error tracking)
VITE_SENTRY_DSN=

# ============================================
# FEATURE FLAGS (Optionnel)
# ============================================

# Activer/désactiver fonctionnalités
VITE_ENABLE_MANUAL_TRADE=true
VITE_ENABLE_FORCE_REFLECTION=true
VITE_ENABLE_EXPORT=true

# ============================================
# UI SETTINGS (Optionnel)
# ============================================

# Refresh rates (millisecondes)
VITE_PORTFOLIO_REFRESH_MS=5000
VITE_CHART_REFRESH_MS=10000

# Thème par défaut
VITE_DEFAULT_THEME=dark

# Animations
VITE_CHART_ANIMATION=true

# ============================================
# NOTES
# ============================================

# 1. Les variables doivent commencer par VITE_
# 2. Créer .env.development pour dev
# 3. Créer .env.production pour prod
# 4. Redémarrer npm run dev après modification
