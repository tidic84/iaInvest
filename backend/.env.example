# ============================================
# TRADING IA AUTO-APPRENANT - CONFIGURATION
# ============================================
# Copiez ce fichier vers .env et personnalisez les valeurs
# Ne commitez JAMAIS votre fichier .env (contient des secrets)

# ============================================
# CONFIGURATION GÉNÉRALE
# ============================================

# Environnement: development, staging, production
ENVIRONMENT=development

# Mode debug (True en dev, False en prod)
DEBUG=True

# Clé secrète pour JWT et sessions
# ⚠️ IMPORTANT: Générer avec: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changez-cette-cle-en-production-utilisez-secrets-token-hex-32

# ============================================
# BASE DE DONNÉES
# ============================================

# SQLite (Développement - Simple et rapide)
DATABASE_URL=sqlite:///./trading_ai.db

# PostgreSQL (Production - Recommandé pour déploiement)
# Décommentez et configurez pour production:
# DATABASE_URL=postgresql://trading_user:SecureP@ssw0rd@localhost:5432/trading_ai_db

# Pool de connexions (pour PostgreSQL)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# ============================================
# CLÉS API - OBLIGATOIRE ET OPTIONNELLES
# ============================================

# === XAI API (Grok) - ⚠️ OBLIGATOIRE ===
# Obtenir sur: https://x.ai/api
# Coût: ~$4-6/semaine en mode paper trading
# La clé commence par "xai-"
XAI_API_KEY=xai-votre-cle-xai-ici-obligatoire

# Modèle Grok à utiliser (OPTIONNEL - "grok-2-1212" par défaut)
# Modèles disponibles: grok-2-1212, grok-vision-beta, grok-2-vision-1212
# GROK_MODEL=grok-2-1212

# === TWITTER/X API - OPTIONNEL ===
# Pour analyse de sentiment sur les cryptos/actions
# Obtenir sur: https://developer.twitter.com
# Gratuit jusqu'à 50 requêtes/15min
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=

# === GOOGLE SEARCH API - OPTIONNEL ===
# Pour recherches internet temps réel
# Obtenir sur: https://developers.google.com/custom-search
# Gratuit: 100 requêtes/jour
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# === BINANCE API - OPTIONNEL (LIVE TRADING CRYPTO) ===
# ⚠️ ATTENTION: Seulement si vous voulez trader avec ARGENT RÉEL!
# Obtenir sur: https://www.binance.com/en/my/settings/api-management
# Permissions: Enable Reading + Enable Spot Trading (PAS de Withdrawals!)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ============================================
# CONFIGURATION TRADING
# ============================================

# === MODE DE TRADING ===
# - "paper": Simulation (aucun argent réel) - RECOMMANDÉ AU DÉBUT
# - "live": Trading réel (argent réel en jeu)
# ⚠️ Testez TOUJOURS en paper d'abord!
TRADING_MODE=paper

# Capital initial (USD)
# En mode paper: montant de départ pour simulation
# En mode live: montant maximum que l'agent peut utiliser
INITIAL_CAPITAL=10000

# Symboles à surveiller (séparés par virgules)
# Crypto: Format "BASE/QUOTE" (ex: BTC/USDT, ETH/USDT)
# Actions: Symbol US (ex: AAPL, TSLA, NVDA, GOOGL)
WATCHED_SYMBOLS=BTC/USDT,ETH/USDT,AAPL,TSLA,NVDA

# === LIMITES DE POSITIONS ===

# Nombre maximum de positions simultanées
# Recommandé: 2-5 pour diversification
MAX_POSITIONS=3

# Taille maximum d'une position (% du capital total)
# Exemple: 20 = max 20% du capital par position
# Recommandé: 15-25%
MAX_POSITION_SIZE_PCT=20

# === RISK MANAGEMENT ===

# Stop-Loss par défaut (% de perte avant vente auto)
# Exemple: 5 = vendre si -5% sur position
# Recommandé: 3-7%
STOP_LOSS_DEFAULT=5

# Take-Profit par défaut (% de gain avant vente auto)
# Exemple: 10 = vendre si +10% sur position
# Recommandé: 8-15%
TAKE_PROFIT_DEFAULT=10

# Drawdown maximum autorisé (% depuis ATH du portfolio)
# Exemple: 20 = stop trading si -20% depuis le plus haut
# Recommandé: 15-25%
MAX_DRAWDOWN=20

# Perte maximum quotidienne (% du capital)
# Exemple: 10 = stop trading si -10% en une journée
# Recommandé: 5-15%
MAX_DAILY_LOSS_PCT=10

# === FRÉQUENCE DE TRADING ===

# Nombre maximum de trades par jour
# Recommandé: 3-10 (évite l'overtrading)
MAX_TRADES_PER_DAY=5

# Intervalle minimum entre deux trades (en secondes)
# 3600 = 1 heure entre chaque trade
# Recommandé: 1800-7200 (30min-2h)
MIN_INTERVAL_BETWEEN_TRADES=3600

# === AUTO-RÉFLEXION ===

# Nombre de trades avant auto-réflexion
# L'IA analysera ses N derniers trades pour apprendre
# Recommandé: 5-10
REFLECTION_INTERVAL=5

# Activer/désactiver l'auto-réflexion
# true = L'IA apprend de ses erreurs
# false = Pas d'apprentissage automatique
REFLECTION_ENABLED=True

# === TRADING AUTONOME (CYCLES GROK) ===

# Intervalle du cycle de découverte (secondes)
# Grok recherche de nouvelles opportunités via web_search + x_search
# 3600 = 1 heure
# Recommandé: 1800-7200 (30min-2h)
DISCOVERY_INTERVAL=3600

# Intervalle du cycle d'analyse (secondes)
# Grok analyse en profondeur les symboles sur la watchlist
# 1800 = 30 minutes
# Recommandé: 900-3600 (15min-1h)
ANALYSIS_INTERVAL=1800

# Intervalle du cycle de monitoring (secondes)
# Grok surveille les positions ouvertes pour breaking news
# 900 = 15 minutes
# Recommandé: 300-900 (5min-15min)
MONITORING_INTERVAL=900

# Nombre de trades fermés avant réflexion stratégique
# Grok évalue sa stratégie et l'ajuste si nécessaire
# Recommandé: 10-20
REFLECTION_TRADES_THRESHOLD=10

# === STRATÉGIE AUTONOME ===

# Création automatique de stratégie au démarrage
# true = Grok crée sa propre stratégie
# false = Utilise une stratégie par défaut
AUTO_STRATEGY_CREATION=true

# Profil de risque pour la stratégie
# conservative, moderate, aggressive
STRATEGY_RISK_PROFILE=moderate

# === WATCHLIST ===

# Taille maximum de la watchlist
# Nombre max de symboles à surveiller simultanément
MAX_WATCHLIST_SIZE=20

# Score minimum pour ajouter à la watchlist (0-10)
# Grok ne garde que les opportunités scorant au-dessus
MIN_OPPORTUNITY_SCORE=6.0

# Nettoyage automatique watchlist (jours)
# Retire les items LOW priority non analysés depuis X jours
AUTO_REMOVE_LOW_PRIORITY_DAYS=7

# ============================================
# CONFIGURATION SERVEUR
# ============================================

# Adresse d'écoute du serveur
# 0.0.0.0 = écoute sur toutes les interfaces (accès externe)
# 127.0.0.1 = localhost uniquement (accès local seulement)
HOST=0.0.0.0

# Port du serveur
# Défaut: 8000
PORT=8000

# Nombre de workers (production)
# Recommandé: 2-4 pour VPS
WORKERS=4

# Timeout des requêtes (secondes)
TIMEOUT=120

# ============================================
# CORS (Cross-Origin Resource Sharing)
# ============================================

# Origins autorisées à accéder à l'API (séparées par virgules)
# Développement local:
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Production (décommentez et modifiez):
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================
# CACHE & OPTIMISATION (Optionnel)
# ============================================

# Redis pour cache (optionnel, améliore perfs)
REDIS_ENABLED=False
REDIS_URL=redis://localhost:6379/0

# Durée de cache (secondes)
SENTIMENT_CACHE_TTL=3600
MARKET_DATA_CACHE_TTL=60
NEWS_CACHE_TTL=1800

# ============================================
# RATE LIMITING
# ============================================

# Limites pour éviter de dépasser quotas APIs

# Grok API
GROK_MAX_CALLS_PER_TRADE=10
GROK_COOLDOWN_SECONDS=180

# Twitter API
TWITTER_MAX_REQUESTS_PER_15MIN=50

# Market Data
MARKET_CHECK_INTERVAL=180

# ============================================
# LOGGING
# ============================================

# Niveau de log: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Développement: DEBUG ou INFO
# Production: WARNING ou ERROR
LOG_LEVEL=INFO

# Fichier de log
LOG_FILE=/tmp/trading-ai-backend.log

# Taille max du fichier avant rotation (bytes)
# 10485760 = 10 MB
LOG_MAX_BYTES=10485760

# Nombre de fichiers de backup
LOG_BACKUP_COUNT=5

# Format JSON (facilite parsing)
LOG_JSON_FORMAT=False

# ============================================
# MONITORING & ALERTES (Optionnel)
# ============================================

# Email notifications via SMTP
SMTP_ENABLED=False
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre-email@gmail.com
SMTP_PASSWORD=votre-app-password
ALERT_EMAIL=votre-email@gmail.com

# Quand envoyer des alertes
ALERT_ON_TRADE=False
ALERT_ON_REFLECTION=True
ALERT_ON_ERROR=True
ALERT_ON_LOSS_THRESHOLD=-5

# ============================================
# SÉCURITÉ
# ============================================

# JWT pour authentification (si ajoutée)
JWT_SECRET_KEY=autre-cle-secrete-pour-jwt
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Rate limiting API
API_RATE_LIMIT=100

# ============================================
# BACKUP (Optionnel)
# ============================================

# Backup automatique de la DB
AUTO_BACKUP_ENABLED=False
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=7
BACKUP_PATH=/home/trading/backups

# ============================================
# NOTES IMPORTANTES
# ============================================

# 1. OBTENIR CLÉ GROK (OBLIGATOIRE):
#    https://x.ai/api
#    Coût: ~$20-25/mois en mode paper

# 2. COMMENCER EN MODE PAPER:
#    TRADING_MODE=paper
#    Testez au moins 1 semaine avant live!

# 3. SÉCURITÉ:
#    - Ne JAMAIS commiter le fichier .env
#    - Changer SECRET_KEY en production
#    - Activer 2FA sur tous les comptes API
#    - Binance: PAS de withdrawals permissions

# 4. MONITORING:
#    - Surveillez les logs: tail -f /tmp/trading-ai-backend.log
#    - Vérifiez win rate après 50+ trades
#    - Activez alertes email en production

# 5. SUPPORT:
#    - Voir INSTALLATION.md pour troubleshooting
#    - Voir CONFIGURATION.md pour détails
#    - GitHub Issues pour questions
